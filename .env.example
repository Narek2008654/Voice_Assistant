# LiveKit server credentials (https://cloud.livekit.io)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# Groq API key — used for Whisper STT and Llama answer generation (https://console.groq.com)
GROQ_API_KEY=your_groq_api_key

# OpenAI API key — used for TTS and STT post-processing (https://platform.openai.com)
OPENAI_API_KEY=your_openai_api_key
